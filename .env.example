# GitHub Models (LLM)
GITHUB_TOKEN=your_github_token_here
LLM_MODEL=claude-haiku-4-5
LLM_AUX_MODEL=gpt-4o-mini
LLM_BASE_URL=https://models.inference.ai.azure.com

# Anthropic API (fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot
TELEGRAM_API_KEY=your_telegram_api_key_here

# Firebase (JSON completo del service account — Firestore)
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Restaurante
RESTAURANT_NAME=Acaxeemx
TIMEZONE=America/Mazatlan
MAX_CONVERSATION_HISTORY=20
LLM_MAX_RETRIES=3
